<file path="frontend/src/styles/auth.css">
/* ============================================
   AUTH PAGES (LOGIN + REGISTER)
   ============================================ */

@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap');

/* ============================================
   ANIMATIONS
   ============================================ */

@keyframes slideUp { 
  from { opacity: 0; transform: translateY(30px); } 
  to { opacity: 1; transform: translateY(0); } 
}

@keyframes shake { 
  0%, 100% { transform: translateX(0); } 
  25% { transform: translateX(-8px); } 
  75% { transform: translateX(8px); } 
}

/* ============================================
   PAGE WRAPPER
   ============================================ */

.auth-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #030810 0%, #0d2035 50%, #030810 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'DM Sans', sans-serif;
  padding: 20px;
}

/* ============================================
   AUTH CARD (Login/Register box)
   ============================================ */

.auth-card {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 16px;
  padding: 48px 40px;
  width: 100%;
  max-width: 420px;
  backdrop-filter: blur(20px);
  animation: slideUp 0.5s ease;
  position: relative;
  overflow: hidden;
}

.auth-card-accent {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, #1D9E75, transparent);
}

/* ============================================
   AUTH LOGO HEADER
   ============================================ */

.auth-logo-wrapper {
  text-align: center;
  margin-bottom: 32px;
}

.auth-logo-icon {
  width: 56px;
  height: 56px;
  background: linear-gradient(135deg, #1D9E75, #0d7a5a);
  border-radius: 12px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
  font-size: 24px;
}

.auth-logo-title {
  font-size: 24px;
  font-weight: 700;
  color: white;
  margin: 0 0 4px;
  letter-spacing: 1px;
}

/* ✅ FIX 1: letterSpacing → letter-spacing */
.auth-logo-subtitle {
  color: rgba(255,255,255,0.3);
  margin: 0;
  font-size: 13px;
  letter-spacing: 1px;
}

/* ============================================
   FORM INPUTS
   ============================================ */

.auth-input {
  width: 100%;
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 8px;
  padding: 12px 16px;
  font-size: 14px;
  outline: none;
  transition: all 0.3s ease;
  box-sizing: border-box;
  background: rgba(255,255,255,0.05);
  color: white;
  font-family: 'DM Sans', sans-serif;
}

.auth-input::placeholder {
  color: rgba(255,255,255,0.25);
}

.auth-input:focus {
  border-color: #1D9E75;
  background: rgba(255,255,255,0.08);
  box-shadow: 0 0 0 3px rgba(29,158,117,0.15);
}

.auth-label {
  display: block;
  font-size: 12px;
  font-weight: 600;
  color: rgba(255,255,255,0.5);
  margin-bottom: 6px;
  letter-spacing: 1px;
  text-transform: uppercase;
}

/* ============================================
   ROLE TABS (Student / Admin)
   ============================================ */

.role-tabs {
  display: flex;
  gap: 8px;
  margin-bottom: 24px;
}

.role-tab {
  flex: 1;
  padding: 10px;
  border: 1px solid rgba(255,255,255,0.1);
  background: rgba(255,255,255,0.03);
  border-radius: 8px;
  cursor: pointer;
  font-weight: 600;
  font-size: 13px;
  transition: all 0.3s ease;
  color: rgba(255,255,255,0.5);
  font-family: 'DM Sans', sans-serif;
}

.role-tab.active {
  background: #1D9E75;
  color: white;
  border-color: #1D9E75;
}

.role-tab:hover:not(.active) {
  border-color: rgba(29,158,117,0.5);
  color: white;
}

/* ============================================
   AUTH BUTTONS
   ============================================ */

.auth-btn {
  width: 100%;
  padding: 14px;
  background: linear-gradient(135deg, #1D9E75, #0d7a5a);
  color: white;
  border: none;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  font-family: 'DM Sans', sans-serif;
  letter-spacing: 1px;
}

.auth-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(29,158,117,0.3);
}

.auth-btn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  transform: none;
}

/* ============================================
   ERROR MESSAGE
   ============================================ */

.auth-error {
  background: rgba(220,38,38,0.1);
  border: 1px solid rgba(220,38,38,0.3);
  color: #f87171;
  padding: 12px 16px;
  border-radius: 8px;
  margin-bottom: 16px;
  font-size: 13px;
  animation: shake 0.3s ease;
}

/* ============================================
   FOOTER LINK
   ============================================ */

.auth-footer {
  text-align: center;
  font-size: 13px;
  color: rgba(255,255,255,0.3);
  margin-top: 24px;
  margin-bottom: 0;
}

.auth-link {
  color: #1D9E75;
  font-weight: 700;
  text-decoration: none;
  transition: color 0.3s;
}

.auth-link:hover {
  color: #4ecba0;
}

/* ============================================
   REGISTER PAGE EXTRAS
   ============================================ */

/* Progress Indicator */
.progress-bar {
  display: flex;
  gap: 8px;
  margin-bottom: 28px;
}

.progress-step {
  flex: 1;
  height: 3px;
  border-radius: 2px;
  background: rgba(255,255,255,0.1);
  transition: all 0.3s;
}

.progress-step.active {
  background: #1D9E75;
}

/* Success Message */
.auth-success {
  background: rgba(29,158,117,0.1);
  border: 1px solid rgba(29,158,117,0.3);
  color: #1D9E75;
  padding: 12px 16px;
  border-radius: 8px;
  margin-bottom: 16px;
  font-size: 13px;
}

/* Admin Code Box */
.admin-code-box {
  background: rgba(234,179,8,0.08);
  border: 1px solid rgba(234,179,8,0.2);
  border-radius: 8px;
  padding: 16px;
}

.admin-code-hint {
  font-size: 12px;
  color: rgba(234,179,8,0.6);
  margin-top: 6px;
  margin-bottom: 0;
}

/* ============================================
   OTP EMAIL BOX
   ============================================ */

.otp-email-box {
  text-align: center;
  padding: 16px;
  background: rgba(29,158,117,0.05);
  border: 1px solid rgba(29,158,117,0.15);
  border-radius: 8px;
}

.otp-email-icon {
  font-size: 32px;
  margin-bottom: 8px;
}

.otp-email-text {
  color: rgba(255,255,255,0.5);
  font-size: 13px;
  margin: 0;
}

/* ============================================
   OTP 6-BOX INPUT
   ============================================ */

.otp-boxes-container {
  display: flex;
  gap: 10px;
  justify-content: center;
  margin: 12px 0;
}

/* ✅ FIX 2 & 3: appearance: none added */
.otp-box {
  width: 48px;
  height: 56px;
  text-align: center;
  font-size: 22px;
  font-weight: 700;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.06);
  border: 2px solid rgba(255, 255, 255, 0.15);
  border-radius: 12px;
  outline: none;
  transition: all 0.2s ease;
  caret-color: #1D9E75;
  -webkit-appearance: none;
  -moz-appearance: textfield;
  appearance: none;
  font-family: 'DM Sans', sans-serif;
}

.otp-box--filled {
  border-color: #1D9E75;
  background: rgba(29, 158, 117, 0.1);
  box-shadow: 0 0 12px rgba(29, 158, 117, 0.2);
}

.otp-box:focus {
  border-color: #1D9E75 !important;
  background: rgba(29, 158, 117, 0.12) !important;
  box-shadow: 0 0 0 3px rgba(29, 158, 117, 0.2),
              0 0 18px rgba(29, 158, 117, 0.15) !important;
  transform: scale(1.08);
}

@media (max-width: 400px) {
  .otp-box {
    width: 40px;
    height: 48px;
    font-size: 18px;
    border-radius: 10px;
  }
  .otp-boxes-container {
    gap: 7px;
  }
}

/* ============================================
   RESEND & BACK BUTTONS
   ============================================ */

.btn-resend {
  background: none;
  border: none;
  cursor: pointer;
  color: #1D9E75;
  font-size: 13px;
  font-family: 'DM Sans', sans-serif;
  transition: color 0.3s;
}

.btn-resend:disabled {
  cursor: not-allowed;
  color: rgba(255,255,255,0.2);
}

.btn-resend:not(:disabled):hover {
  color: #4ecba0;
}

.btn-back-step {
  background: none;
  border: 1px solid rgba(255,255,255,0.1);
  color: rgba(255,255,255,0.4);
  padding: 10px;
  border-radius: 8px;
  cursor: pointer;
  font-size: 13px;
  font-family: 'DM Sans', sans-serif;
  transition: all 0.3s;
}

.btn-back-step:hover {
  border-color: #1D9E75;
  color: #1D9E75;
}
</file>

