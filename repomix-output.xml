  border-color: rgba(29,158,117,0.2); 
  transform: translateY(-8px); 
  box-shadow: 0 15px 30px rgba(0,0,0,0.3);
}

.feat-card:hover::before { 
  transform: scaleX(1); 
}

/* ============================================
   EMOJI ANIMATIONS
   ============================================ */

.emoji { 
  display: inline-block; 
  transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
}

.feat-card:hover .emoji, 
.emoji:hover { 
  transform: scale(1.4) rotate(15deg); 
  text-shadow: 0 0 15px rgba(255,255,255,0.4); 
}

/* ============================================
   HOVER GLOW
   ============================================ */

.hover-glow { 
  transition: all 0.4s ease; 
}

.hover-glow:hover { 
  transform: scale(1.08); 
  filter: drop-shadow(0 0 15px rgba(29,158,117,0.6)); 
}

/* ============================================
   FLOATING ANIMATION
   ============================================ */

@keyframes float {
  0% { transform: translateY(0px); }
  50% { transform: translateY(-20px); }
  100% { transform: translateY(0px); }
}

.floating { 
  animation: float 6s ease-in-out infinite; 
}

/* ============================================
   SPIN & PULSE
   ============================================ */

@keyframes spin { 
  from { transform: rotate(0deg); } 
  to { transform: rotate(360deg); } 
}

@keyframes pulse { 
  0%, 100% { opacity: 1; box-shadow: 0 0 10px #1D9E75; } 
  50% { opacity: 0.4; box-shadow: none; } 
}

/* ============================================
   NAVIGATION
   ============================================ */

.nav-link {
  color: rgba(255,255,255,0.5); 
  text-decoration: none;
  font-size: 12px; 
  font-weight: 500; 
  letter-spacing: 2px;
  text-transform: uppercase; 
  transition: color 0.3s, transform 0.3s;
  background: none; 
  border: none;
  cursor: pointer;
}

.nav-link:hover { 
  color: #1D9E75; 
  transform: translateY(-2px); 
}

/* ✅ Hamburger — desktop pe hidden */
.nav-hamburger {
  display: none;
}

/* ============================================
   STATS
   ============================================ */

.stat-num { 
  font-family: 'Cormorant Garamond', serif; 
  font-size: 56px; 
  font-weight: 300; 
  color: #1D9E75; 
  line-height: 1; 
  transition: transform 0.4s; 
}

div:hover > .stat-num { 
  transform: scale(1.1); 
}

/* ============================================
   DIVIDER
   ============================================ */

.divider { 
  width: 60px; 
  height: 1px; 
  background: #1D9E75; 
  margin: 20px 0; 
  transition: width 0.4s; 
}

div:hover > .divider { 
  width: 100px; 
  box-shadow: 0 0 10px #1D9E75; 
}

/* ============================================
   STEP CARDS
   ============================================ */

.step-num {
  font-family: 'Cormorant Garamond', serif; 
  font-size: 80px; 
  font-weight: 300;
  color: rgba(29,158,117,0.1); 
  line-height: 1;
  position: absolute; 
  top: -10px; 
  right: 20px; 
  transition: color 0.4s, transform 0.4s;
}

.step-card:hover .step-num { 
  color: rgba(29,158,117,0.2); 
  transform: scale(1.1) translateX(-10px); 
}

/* ============================================
   TABLET (769px - 1024px)
   ============================================ */

@media (max-width: 1024px) and (min-width: 769px) {
  .hero-grid { gap: 40px !important; }
  .hero-visual { height: 380px !important; }
  .about-grid { gap: 40px !important; }
  .steps-grid { grid-template-columns: 1fr 1fr !important; }
  .feat-grid { grid-template-columns: repeat(2, 1fr) !important; }
  .stat-num { font-size: 42px !important; }
  .stats-row { gap: 28px !important; }
}

/* ============================================
   MOBILE (max 768px)
   ============================================ */

@media (max-width: 768px) {

  /* Cursor hide */
  .cursor-dot,
  .cursor-ring { 
    display: none !important; 
  }

  /* Hero */
  .hero-grid { 
    grid-template-columns: 1fr !important; 
    padding: 40px 5% !important;
    gap: 0 !important;
  }

  /* ✅ 3D Scene — hide nahi, chhota karo */
  .hero-visual { 
    display: flex !important;
    height: 280px !important;
    width: 100% !important;
    margin-top: 16px !important;
  }

  /* About */
  .about-grid { 
    grid-template-columns: 1fr !important; 
    gap: 32px !important;
  }
  .about-visual { 
    display: none !important; 
  }

  /* Steps */
  .steps-grid { 
    grid-template-columns: 1fr !important; 
  }

  /* Features */
  .feat-grid { 
    grid-template-columns: 1fr !important; 
  }

  /* Navbar */
  .nav-links { display: none !important; }
  .nav-actions { display: none !important; }
  .nav-hamburger { display: flex !important; }

  /* Stats */
  .stats-row { 
    gap: 20px !important; 
    flex-wrap: wrap !important;
  }
  .stat-num { font-size: 38px !important; }

  /* CTA Buttons */
  .cta-btns { 
    flex-direction: column !important; 
    align-items: stretch !important; 
  }
  .btn-primary,
  .btn-outline {
    width: 100% !important;
    text-align: center !important;
    padding: 14px 24px !important;
  }

  /* Developer */
  .dev-card { padding: 28px 16px !important; }
  .dev-inner { 
    flex-direction: column !important; 
    text-align: center !important; 
    gap: 24px !important;
  }

  /* Floating off */
  .floating { animation: none !important; }
}

/* ============================================
   PREFERS REDUCED MOTION
   ============================================ */

@media (prefers-reduced-motion: reduce) {
  .floating,
  .fade-up,
  .fade-left,
  .fade-right {
    animation: none !important;
    transition: none !important;
    opacity: 1 !important;
    transform: none !important;
  }
}
/* ============================================
   PREMIUM 3D ICON (CSS-based)
   ============================================ */

.icon-3d-wrapper {
  position: relative;
  width: 80px;
  height: 80px;
  perspective: 800px;
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-3d-cube {
  position: relative;
  width: 60px;
  height: 60px;
  transform-style: preserve-3d;
  animation: cube-rotate 8s infinite linear, cube-float 3s infinite ease-in-out;
  transition: animation-duration 0.4s ease;
}

.icon-3d-face {
  position: absolute;
  width: 60px;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  background: linear-gradient(135deg, rgba(29,158,117,0.15) 0%, rgba(29,158,117,0.05) 100%);
  border: 1px solid rgba(29,158,117,0.3);
  border-radius: 8px;
  backdrop-filter: blur(10px);
  box-shadow: 
    inset 0 0 20px rgba(29,158,117,0.1),
    0 0 15px rgba(29,158,117,0.2);
}

.icon-3d-front  { transform: translateZ(30px); }
.icon-3d-back   { transform: translateZ(-30px) rotateY(180deg); }
.icon-3d-right  { transform: rotateY(90deg) translateZ(30px); }
.icon-3d-left   { transform: rotateY(-90deg) translateZ(30px); }
.icon-3d-top    { transform: rotateX(90deg) translateZ(30px); }
.icon-3d-bottom { transform: rotateX(-90deg) translateZ(30px); }

.icon-3d-glow {
  position: absolute;
  width: 80px;
  height: 80px;
  background: radial-gradient(circle, rgba(29,158,117,0.4) 0%, transparent 70%);
  filter: blur(20px);
  z-index: -1;
  animation: glow-pulse 3s infinite ease-in-out;
}

@keyframes cube-rotate {
  from { transform: rotateX(0deg) rotateY(0deg); }
  to   { transform: rotateX(360deg) rotateY(360deg); }
}

@keyframes cube-float {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-8px); }
}

@keyframes glow-pulse {
  0%, 100% { opacity: 0.4; transform: scale(1); }
  50%      { opacity: 0.8; transform: scale(1.2); }
}

/* ✅ Hover effect — speed up rotation */
.feat-card:hover .icon-3d-cube {
  animation-duration: 3s, 1.5s;
}

.feat-card:hover .icon-3d-glow {
  animation-duration: 1.5s;
}

/* Mobile — disable heavy animations */
@media (max-width: 768px) {
  .icon-3d-cube {
    animation-duration: 12s, 4s;
  }
}
/* ============================================
   PREMIUM 3D GRADUATION CAP (About Section)
   ============================================ */

.grad-cap-wrapper {
  position: relative;
  width: 320px;
  height: 400px;
  display: flex;
  align-items: center;
  justify-content: center;
  perspective: 1000px;
}

.grad-cap-scene {
  position: relative;
  width: 200px;
  height: 200px;
  transform-style: preserve-3d;
  animation: grad-rotate 12s infinite linear, grad-float 4s infinite ease-in-out;
}

.grad-cap-top {
  position: absolute;
  width: 200px;
  height: 200px;
  display: flex;
  align-items: center;
  justify-content: center;
  transform-style: preserve-3d;
}

.grad-cap-face {
  position: absolute;
  width: 200px;
  height: 200px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 140px;
  filter: drop-shadow(0 0 30px rgba(29,158,117,0.6));
}

.grad-cap-face-top {
  transform: translateZ(20px);
}

.grad-cap-tassel {
  position: absolute;
  width: 4px;
  height: 60px;
  background: linear-gradient(180deg, #1D9E75 0%, #4ecba0 100%);
  top: 50%;
  left: 60%;
  transform: translateZ(40px) rotate(15deg);
  border-radius: 2px;
  box-shadow: 0 0 10px rgba(29,158,117,0.8);
  animation: tassel-swing 3s infinite ease-in-out;
  transform-origin: top center;
}

.grad-cap-tassel::after {
  content: '';
  position: absolute;
  bottom: -8px;
  left: -6px;
  width: 16px;
  height: 16px;
  background: radial-gradient(circle, #4ecba0, #1D9E75);
  border-radius: 50%;
  box-shadow: 0 0 15px rgba(29,158,117,1);
}

.grad-cap-glow {
  position: absolute;
  width: 280px;
  height: 280px;
  background: radial-gradient(circle, rgba(29,158,117,0.4) 0%, transparent 70%);
  border-radius: 50%;
  filter: blur(40px);
  z-index: -1;
  animation: grad-glow-pulse 3s infinite ease-in-out;
}

.grad-particle {
  position: absolute;
  font-size: 24px;
  filter: drop-shadow(0 0 10px rgba(29,158,117,0.5));
  animation: particle-orbit 8s infinite linear;
}

.grad-particle-1 {
  top: 10%;
  left: 5%;
  animation-delay: 0s;
}

.grad-particle-2 {
  top: 15%;
  right: 5%;
  animation-delay: 2s;
}

.grad-particle-3 {
  bottom: 15%;
  left: 5%;
  animation-delay: 4s;
}

.grad-particle-4 {
  bottom: 10%;
  right: 5%;
  animation-delay: 6s;
}

.grad-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 100px;
  height: 60px;
  background: linear-gradient(135deg, #1D9E75, #0d7a5a);
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 15px 30px rgba(29,158,117,0.5);
  cursor: pointer;
  transition: transform 0.3s;
  z-index: 5;
  animation: badge-pulse 3s infinite ease-in-out;
}

.grad-badge:hover {
  transform: scale(1.1) rotate(5deg);
}

@keyframes grad-rotate {
  from { transform: rotateY(0deg); }
  to   { transform: rotateY(360deg); }
}

@keyframes grad-float {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-15px); }
}

@keyframes tassel-swing {
  0%, 100% { transform: translateZ(40px) rotate(15deg); }
  50%      { transform: translateZ(40px) rotate(-15deg); }
}

@keyframes grad-glow-pulse {
  0%, 100% { opacity: 0.5; transform: scale(1); }
  50%      { opacity: 0.9; transform: scale(1.15); }
}

@keyframes particle-orbit {
  0%   { transform: translate(0, 0) rotate(0deg); opacity: 0.6; }
  25%  { transform: translate(30px, -20px) rotate(90deg); opacity: 1; }
  50%  { transform: translate(0, -40px) rotate(180deg); opacity: 0.6; }
  75%  { transform: translate(-30px, -20px) rotate(270deg); opacity: 1; }
  100% { transform: translate(0, 0) rotate(360deg); opacity: 0.6; }
}

@keyframes badge-pulse {
  0%, 100% { box-shadow: 0 15px 30px rgba(29,158,117,0.5); }
  50%      { box-shadow: 0 15px 50px rgba(29,158,117,0.8), 0 0 30px rgba(29,158,117,0.6); }
}

/* Mobile — disable heavy animations */
@media (max-width: 768px) {
  .grad-cap-wrapper {
    width: 240px;
    height: 320px;
  }
  
  .grad-cap-scene {
    width: 150px;
    height: 150px;
  }
  
  .grad-cap-face {
    width: 150px;
    height: 150px;
    font-size: 100px;
  }
  
  .grad-cap-glow {
    width: 200px;
    height: 200px;
  }
}
