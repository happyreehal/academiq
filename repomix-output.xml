        }
        .input-field::placeholder { color:rgba(255,255,255,0.25); }
        .input-field:focus { border-color:#1D9E75; background:rgba(255,255,255,0.08); box-shadow:0 0 0 3px rgba(29,158,117,0.15); }
        .reg-btn {
