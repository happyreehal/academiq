  border-color: #1D9E75;
  color: #1D9E75;
}

/* ============================================
   FORM INPUTS
   ============================================ */

.student-form-input { 
  width: 100%; 
  padding: 11px 14px; 
  border: 1px solid rgba(255,255,255,0.1); 
  border-radius: 4px; 
  font-size: 14px; 
  font-family: 'DM Sans', sans-serif; 
  color: white; 
  background: rgba(255,255,255,0.03); 
  outline: none; 
  transition: border-color 0.2s; 
  box-sizing: border-box; 
}

.student-form-input:focus { 
  border-color: #1D9E75; 
  background: rgba(255,255,255,0.06); 
}

.student-form-input:disabled { 
  opacity: 0.5; 
  cursor: not-allowed; 
}

.student-form-input option { 
  background: #040b14; 
  color: white; 
}

.student-label {
  display: block;
  font-size: 12px;
  font-weight: 500;
  color: rgba(255,255,255,0.5);
  margin-bottom: 8px;
  letter-spacing: 1px;
  text-transform: uppercase;
}

/* ============================================
   FILTER CARD
   ============================================ */

.filter-card {
  background: rgba(255,255,255,0.02);
  border-radius: 4px;
  border: 1px solid rgba(255,255,255,0.06);
  padding: 36px;
  margin-bottom: 30px;
  backdrop-filter: blur(20px);
}

.filter-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 28px;
  font-weight: 400;
  color: white;
  margin: 0 0 24px;
}

.filter-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

.btn-search {
  margin-top: 28px;
  background: linear-gradient(135deg, #1D9E75, #0d7a5a);
  color: white;
  border: none;
  padding: 14px 32px;
  border-radius: 4px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  font-family: 'DM Sans', sans-serif;
  letter-spacing: 1px;
  transition: all 0.3s;
}

.btn-search:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 25px rgba(29,158,117,0.3);
}

.btn-search:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

/* ============================================
   RESULTS CARD
   ============================================ */

.results-card {
  background: rgba(255,255,255,0.02);
  border-radius: 4px;
  border: 1px solid rgba(255,255,255,0.06);
  padding: 36px;
  backdrop-filter: blur(20px);
}

.results-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
}

.results-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 28px;
  font-weight: 400;
  color: white;
  margin: 0;
}

.results-count {
  background: rgba(29,158,117,0.1);
  border: 1px solid rgba(29,158,117,0.3);
  color: #1D9E75;
  border-radius: 2px;
  padding: 6px 14px;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 1px;
}

.no-results {
  text-align: center;
  padding: 60px 20px;
  color: rgba(255,255,255,0.3);
}

.no-results-icon {
  font-size: 42px;
  margin-bottom: 16px;
  opacity: 0.5;
}

.no-results-text {
  font-weight: 300;
  letter-spacing: 1px;
}

/* ============================================
   PAPER CARDS
   ============================================ */

.student-paper-card { 
  background: rgba(255,255,255,0.02); 
  border: 1px solid rgba(255,255,255,0.06); 
  border-radius: 4px; 
  padding: 20px 24px; 
  display: flex; 
  justify-content: space-between; 
  align-items: center; 
  flex-wrap: wrap; 
  gap: 12px; 
  transition: all 0.4s ease; 
  position: relative; 
  overflow: hidden;
}

.student-paper-card:hover { 
  background: rgba(29,158,117,0.04); 
  border-color: rgba(29,158,117,0.2); 
  transform: translateY(-2px); 
}

.paper-title {
  font-weight: 500;
  color: white;
  font-size: 16px;
  margin-bottom: 6px;
}

.paper-year {
  color: #1D9E75;
}

.paper-meta {
  color: rgba(255,255,255,0.4);
  font-size: 13px;
  font-weight: 300;
}

/* ============================================
   ACTION BUTTONS
   ============================================ */

.btn-view { 
  background: rgba(255,255,255,0.05); 
  color: white; 
  padding: 8px 16px; 
  border-radius: 4px; 
  font-size: 13px; 
  font-weight: 500; 
  text-decoration: none; 
  display: inline-block; 
  border: 1px solid rgba(255,255,255,0.1); 
  transition: all 0.3s;
}

.btn-view:hover { 
  background: rgba(255,255,255,0.1); 
}

.btn-download { 
  background: linear-gradient(135deg, #1D9E75, #0d7a5a); 
  color: white; 
  padding: 8px 16px; 
  border-radius: 4px; 
  font-size: 13px; 
  font-weight: 500; 
  text-decoration: none; 
  border: none; 
  display: inline-block; 
  transition: all 0.3s;
}

.btn-download:hover { 
  box-shadow: 0 10px 20px rgba(29,158,117,0.3); 
  transform: translateY(-1px); 
}

/* ============================================
   MOBILE RESPONSIVE
   ============================================ */

@media (max-width: 768px) {
  .filter-grid {
    grid-template-columns: 1fr !important;
  }
  
  .student-navbar {
    padding: 0 4%;
  }
  
  .filter-card, .results-card {
    padding: 24px;
  }
}
.btn-reset {
  padding: 12px 20px;
  background: transparent;
  border: 1px solid rgba(255,255,255,0.1);
  color: rgba(255,255,255,0.4);
  border-radius: 8px;
  cursor: pointer;
  font-size: 13px;
  font-family: 'DM Sans', sans-serif;
  transition: all 0.3s;
}

.btn-reset:hover {
  border-color: #EF4444;
  color: #EF4444;
}
