          {rejectedStudents.map(s => (
            <StudentItem 
              key={s.email} 
              student={s}
              actions={
                <>
                  <button className="btn-approve" onClick={() => approveStudent(s.email)}>✅ Approve</button>
                  <button className="btn-danger" onClick={() => removeStudent(s.email)}>🗑️ Remove</button>
                </>
              }
            />
          ))}
        </div>
      )}
    </div>
  );
}
